# Copiez ce fichier en .env et remplissez avec vos vraies valeurs
# Ne JAMAIS commiter le fichier .env dans git

# --- Jira ---
JIRA_URL=https://votrenom.atlassian.net
JIRA_EMAIL=votre-email@exemple.com
JIRA_API_TOKEN=collez_votre_token_ici
JIRA_PROJECT_KEY=KAN

# --- Sécurité API (mode simple) ---
API_ACCESS_TOKEN=un-token-secret-long
API_USER_EMAIL=votre-email@exemple.com
API_ALLOWED_PROJECTS=KAN

# --- Sécurité API (mode multi-utilisateurs, remplace les 3 lignes ci-dessus) ---
# API_USERS_JSON={"token-user1": {"email": "user1@exemple.com", "allowed_project_ids": ["KAN"]}, "token-user2": {"email": "user2@exemple.com", "allowed_project_ids": ["KAN", "PTI"]}}

# --- Phase 2 : RAG / Assistant IA ---
# Modèle Ollama à utiliser (doit être installé : ollama pull qwen2.5:7b)
OLLAMA_MODEL=llama3.2:3b
# Dossier local où ChromaDB persiste ses données
CHROMA_PATH=./chroma_db
# Nombre de documents renvoyés par la recherche sémantique
RAG_N_RESULTS=4

# --- Phase 3 : Notifications Microsoft Teams (Volet 1 — Incoming Webhook) ---
# Dans Teams : clic droit sur le canal cible → Connecteurs → Incoming Webhook → Créer
# Coller l'URL générée ci-dessous. Laisser vide pour désactiver les notifications.
TEAMS_WEBHOOK_URL=
